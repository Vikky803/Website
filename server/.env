# ── Dashboard server ─────────────────────────────────────
DASHBOARD_PORT=3001

# JWT signing secret — generate your own random one before going live:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The value below is a placeholder — replace it, don't ship this one.
DASHBOARD_JWT_SECRET=REPLACE_ME_WITH_A_RANDOM_64_CHAR_STRING

# Which origins are allowed to load the dashboard (comma-separated, no spaces).
# Add your GitHub Pages URL here once you deploy the frontend, e.g.:
#   https://yourname.github.io
# For local testing, http://localhost:5500 (Live Server / http.server default) works.
DASHBOARD_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ── Access codes (3 keyholders) ──────────────────────────
# These are salted PBKDF2 hashes (salt:hash), already generated for the
# 3 passwords you gave me — they work as-is, no setup needed to test.
#
# To change a password later, run:
#   node hash-password.js "yourNewPassword"
# and paste the printed value in as the new SEAT_n_HASH.
SEAT_1_HASH=5100b39108bcf84c00cb869a387d90e3:e08ed7f1b296a62e4c27c60c9cc24eaeabcfbe787967084e0446097d472e835dc002d3efe48e740bf5d78f7b0cc85f495b70f04473fe7a5be406857bc7514b70
SEAT_2_HASH=311be22f9a91dff6f22a47a695d82b1d:bb93c9f7af6441150ac2862b01a6380f9bdab05f0d8077658738991ce4861b719fc7e984ff789f7435106fa7ccb78ce456477805db4038250625202a83736afb
SEAT_3_HASH=bb1ee7e4fe26173442f9847724225c6a:23805d6e9acf5f306c15f8814fd26ac7fbdbd96fddfda370663c831218288765ccd9a375d52ce8cd2e1df91b4ab040d396a503aeac72bda3a2cd1b86eac2165c
